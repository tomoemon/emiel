{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "pnpm run fmt && pnpm run lint && pnpm run test || exit 2",
            "timeout": 120,
            "statusMessage": "Running fmt, lint and test..."
          }
        ]
      }
    ]
  }
}
