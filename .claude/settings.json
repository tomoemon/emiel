{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git add *)",
            "command": "pnpm run fmt || exit 2",
            "statusMessage": "Running fmt..."
          },
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "pnpm run lint && pnpm run test && pnpm run build:all || exit 2",
            "timeout": 300,
            "statusMessage": "Running lint, test and build:all..."
          }
        ]
      }
    ]
  }
}
