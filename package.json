{
  "name": "emiel",
  "author": "tomoemon",
  "packageManager": "pnpm@11.1.2",
  "version": "0.4.1",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tomoemon/emiel"
  },
  "bugs": {
    "url": "https://github.com/tomoemon/emiel/issues"
  },
  "files": [
    "dist"
  ],
  "module": "./dist/index.js",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./presets/*": {
      "import": {
        "types": "./dist/types/impl/presets/*.d.ts",
        "default": "./dist/impl/presets/*.js"
      }
    }
  },
  "scripts": {
    "build": "vite build && tsc",
    "build:all": "pnpm run build && pnpm -r --filter \"./examples/*\" run build",
    "lint": "oxlint --deny-warnings src examples",
    "lint:fix": "oxlint --fix src examples",
    "test": "vitest",
    "fmt": "oxfmt --write src examples '!**/dist'",
    "fmt:check": "oxfmt --check src examples '!**/dist'",
    "show-layout": "npx tsx scripts/show-layout.ts",
    "convert:yab": "npx tsx scripts/yab-to-json-rule.ts",
    "convert:dvorakj": "npx tsx scripts/dvorakj-to-json-rule.ts",
    "show-rule": "npx tsx scripts/show-rule.ts"
  },
  "devDependencies": {
    "@types/estree": "^1.0.9",
    "@types/node": "^25.8.0",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "valibot": "^1.4.0"
  }
}
