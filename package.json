    "fmt:check": "oxfmt --check src"
  },
  "devDependencies": {
    "@base2/pretty-print-object": "^1.0.2",
    "@types/estree": "^1.0.8",
    "@types/node": "^25.5.2",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
