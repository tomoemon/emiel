{
  "name": "emiel",
  "author": "tomoemon",
  "packageManager": "pnpm@9.11.0",
  "version": "0.2.0",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tomoemon/emiel"
  },
  "bugs": {
    "url": "https://github.com/tomoemon/emiel/issues"
  },
  "files": [
    "dist"
  ],
  "module": "./dist/index.js",
