{
  "name": "emiel",
  "author": "tomoemon",
  "packageManager": "pnpm@9.11.0",
  "version": "0.2.0",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tomoemon/emiel"
  },
  "bugs": {
    "url": "https://github.com/tomoemon/emiel/issues"
  },
  "files": [
    "dist"
  ],
  "module": "./dist/index.js",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./presets/*": {
      "import": {
        "types": "./dist/types/impl/presets/*.d.ts",
        "default": "./dist/impl/presets/*.js"
      }
    }
  },
  "scripts": {
    "build": "vite build && tsc",
    "build:all": "pnpm run build && pnpm -r --filter \"./examples/*\" run build",
    "lint": "oxlint --deny-warnings src examples",
    "lint:fix": "oxlint --fix src examples",
    "test": "vitest",
    "fmt": "oxfmt --write src examples",
    "fmt:check": "oxfmt --check src examples"
  },
  "devDependencies": {
    "@base2/pretty-print-object": "^1.0.2",
    "@types/estree": "^1.0.8",
    "@types/node": "^25.5.2",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "valibot": "^1.3.1"
  }
}
